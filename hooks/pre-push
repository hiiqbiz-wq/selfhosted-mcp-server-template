#!/bin/sh
# HIIQ Edge gateway — pre-push deploy gate.
# Blocks a push that would crash-loop in Coolify (Docker build + in-image import check).
# Wired via:  git config core.hooksPath hooks   (see README / deploy_gate.py).
# Escape hatch for a doc-only / non-deploy push:  git push --no-verify
set -e

ROOT="$(git rev-parse --show-toplevel)"
echo "[pre-push] HIIQ gateway deploy gate: docker build + in-image import check..."

if command -v uv >/dev/null 2>&1; then
  uv run python "$ROOT/deploy_gate.py"
else
  python "$ROOT/deploy_gate.py"
fi
